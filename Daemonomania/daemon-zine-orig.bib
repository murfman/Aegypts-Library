@Article{Rossini2019,
  author     = {Rossini, Paolo},
  journal    = {Studies in History and Philosophy of Science Part A},
  title      = {New theories for new instruments: {Fabrizio} {Mordente}'s proportional compass and the genesis of {Giordano} {Bruno}'s atomist geometry},
  year       = {2019},
  issn       = {0039-3681},
  month      = aug,
  pages      = {60--68},
  volume     = {76},
  abstract   = {The aim of this article is to shed light on an understudied aspect of Giordano Bruno's intellectual biography, namely, his career as a mathematical practitioner. Early interpreters, especially, have criticized Bruno's mathematics for being “outdated” or too “concrete”. However, thanks to developments in the study of early modern mathematics and the rediscovery of Bruno's first mathematical writings (four dialogues on Fabrizio's Mordente proportional compass), we are in a position to better understand Bruno's mathematics. In particular, this article aims to reopen the question of whether Bruno anticipated the concept of infinitesimal quantity. It does so by providing an analysis of the dialogues on Mordente's compass and of the historical circumstances under which those dialogues were written.},
  doi        = {10.1016/j.shpsa.2018.10.004},
  file       = {ScienceDirect Full Text PDF:https\://www.sciencedirect.com/science/article/abs/pii/S0039368118301912/pdfft?download=true:application/pdf},
  keywords   = {Giordano Bruno, Fabrizio Mordente, History of mathematics, Mathematical practitioners, Proportional compass, Infinitesimals},
  shorttitle = {New theories for new instruments},
  url        = {https://www.sciencedirect.com/science/article/pii/S0039368118301912},
  urldate    = {2025-05-28},
}

